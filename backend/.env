PORT=5001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=base_db
PGUSER=prajwalnavadagp
PGPASSWORD=

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# Google OAuth Credentials (Leave as mock/empty for local mock mode)
GOOGLE_CLIENT_ID=MOCK_CLIENT_ID
GOOGLE_CLIENT_SECRET=MOCK_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your-secret-key-change-in-production-min-32-chars-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# GOOGLE CLOUD (Optional - for Pub/Sub)
# ============================================
GCP_PROJECT_ID=your-project-id
GCP_PUBSUB_TOPIC=base-sync-events
GCP_KMS_KEY_URI=gcp-kms://projects/your-project-id/locations/us-central1/keyRings/base/cryptoKeys/oauth-tokens

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=
