{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",

    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",

    "lib": ["es2022"],

    "types": ["node"],

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "outDir": "./dist",

    "rootDir": "."
  },

  "include": [
    "src/**/*",
    "routes/**/*",
    "services/**/*",
    "middleware/**/*",
    "database/**/*",
    "models/**/*",
    "utils/**/*"
  ]
}